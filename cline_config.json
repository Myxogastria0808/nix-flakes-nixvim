{
  "mcp": {
    "git": {
      "enabled": true,
      "description": "Access Git repository history and status"
    },
    "filesystem": {
      "enabled": true,
      "description": "Search and list files in the repository"
    }
  },
  "instructions": {
    "buildCommand": "nix build .#default",
    "runCommand": "nix run .#default",
    "devEnvironment": "nix develop",
    "updateDependencies": "nix flake update",
    "keyBindingCheck": "grep -r 'key\\s*=' config/"
  }
}
